{
    "name": "n8n-nodes-gravityzone",
    "version": "0.1.6",
    "description": "Custom n8n node which models the Bitdefender GravityZone public API.",
    "license": "MIT",
    "homepage": "https://github.com/DainArtz/n8n-nodes-gravityzone",
    "keywords": [
        "n8n-community-node-package",
        "bitdefender",
        "gravityzone",
        "cybersecurity"
    ],
    "author": {
        "name": "Calin Balan",
        "email": "calin.balan03@gmail.com",
        "url": "https://github.com/DainArtz"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/DainArtz/n8n-nodes-gravityzone.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/GravityZoneApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/GravityZone/GravityZone.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
